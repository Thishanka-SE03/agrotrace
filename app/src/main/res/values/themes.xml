<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.DocumentScanner" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/onPrimary</item>
        <item name="colorPrimaryContainer">@color/primary_container</item>
        <item name="colorOnPrimaryContainer">@color/onPrimaryContainer</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/onSecondary</item>
        <item name="colorSecondaryContainer">@color/secondary_container</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/onSurface</item>
        <item name="colorSurfaceVariant">@color/surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/onSurfaceVariant</item>
        <item name="colorOutline">@color/outline</item>
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.AgroTrace.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.AgroTrace.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.AgroTrace.Large</item>
        <item name="materialCardViewStyle">@style/Widget.AgroTrace.Card</item>
        <item name="materialButtonStyle">@style/Widget.AgroTrace.Button</item>
    </style>

    <style name="ShapeAppearance.AgroTrace.Small" parent="ShapeAppearance.Material3.Corner.Small">
        <item name="cornerSize">12dp</item>
    </style>
    <style name="ShapeAppearance.AgroTrace.Medium" parent="ShapeAppearance.Material3.Corner.Medium">
        <item name="cornerSize">18dp</item>
    </style>
    <style name="ShapeAppearance.AgroTrace.Large" parent="ShapeAppearance.Material3.Corner.Large">
        <item name="cornerSize">28dp</item>
    </style>

    <style name="Widget.AgroTrace.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">1dp</item>
        <item name="cardBackgroundColor">@color/surface</item>
    </style>

    <style name="Widget.AgroTrace.Button" parent="Widget.Material3.Button">
        <item name="android:minHeight">52dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearanceOverlay.AgroTrace.Pill</item>
    </style>

    <style name="AppButton" parent="Widget.AgroTrace.Button" />
    <style name="AppButton.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">52dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearanceOverlay.AgroTrace.Pill</item>
        <item name="strokeColor">@color/outlineVariant</item>
    </style>

    <style name="ShapeAppearanceOverlay.AgroTrace.Pill" parent="">
        <item name="cornerSize">50%</item>
    </style>

    <style name="Widget.AgroTrace.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="android:minHeight">72dp</item>
        <item name="itemIconTint">@color/bottom_nav_item_color</item>
        <item name="itemTextColor">@color/bottom_nav_item_color</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.AgroTrace.BottomNavigation.ActiveIndicator</item>
        <item name="labelVisibilityMode">labeled</item>
    </style>

    <style name="Widget.AgroTrace.BottomNavigation.ActiveIndicator" parent="">
        <item name="android:color">@color/primary_container</item>
        <item name="shapeAppearance">@style/ShapeAppearanceOverlay.AgroTrace.Pill</item>
    </style>
</resources>
