<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="AgroTrace"
        android:textColor="@color/black"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="16dp"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@id/btnHistory"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnForm1"
                style="@style/AppButton.Outlined"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginBottom="12dp"
                android:text="Scan Document Type 1\n(Land Approval Form)"
                android:textAllCaps="false"
                android:textColor="@color/black"
                app:icon="@drawable/ic_description"
                app:iconSize="28dp"
                app:iconPadding="16dp"
                app:iconTint="@color/primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnForm2"
                style="@style/AppButton.Outlined"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginBottom="12dp"
                android:text="Scan Document Type 2\n(Crop Registration Form)"
                android:textAllCaps="false"
                android:textColor="@color/black"
                app:icon="@drawable/ic_description"
                app:iconSize="28dp"
                app:iconPadding="16dp"
                app:iconTint="@color/primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnForm3"
                style="@style/AppButton.Outlined"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginBottom="12dp"
                android:text="Scan Document Type 3\n(Field Inspection Report)"
                android:textAllCaps="false"
                android:textColor="@color/black"
                app:icon="@drawable/ic_description"
                app:iconSize="28dp"
                app:iconPadding="16dp"
                app:iconTint="@color/primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnForm4"
                style="@style/AppButton.Outlined"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginBottom="12dp"
                android:text="Scan Document Type 4\n(Final Field Inspection Report)"
                android:textAllCaps="false"
                android:textColor="@color/black"
                app:icon="@drawable/ic_description"
                app:iconSize="28dp"
                app:iconPadding="16dp"
                app:iconTint="@color/primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnForm5"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginBottom="12dp"
                android:enabled="false"
                android:text="Scan Document Type 5\n(Coming Soon)"
                android:textAllCaps="false"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.Button.Rounded" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnForm6"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginBottom="12dp"
                android:enabled="false"
                android:text="Scan Document Type 6\n(Coming Soon)"
                android:textAllCaps="false"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.Button.Rounded" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnForm7"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginBottom="12dp"
                android:enabled="false"
                android:text="Scan Document Type 7\n(Coming Soon)"
                android:textAllCaps="false"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.Button.Rounded" />

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnHistory"
        style="@style/AppButton.Outlined"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="View History"
        android:textAllCaps="false"
        android:textColor="@color/primary"
        app:icon="@drawable/ic_history"
        app:iconTint="@color/primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>