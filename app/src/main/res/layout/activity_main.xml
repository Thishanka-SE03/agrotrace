<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="24dp">

    <!-- Subtle Grid for Dark Mode -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/grid_bg"
        android:alpha="0.2"
        android:contentDescription="@null"
        app:tint="@color/outline" />

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_leaf"
            android:contentDescription="@null"
            app:tint="@color/secondary" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="AGROTRACE"
            android:textColor="@color/onBackground"
            android:textSize="28sp"
            android:textStyle="bold"
            android:letterSpacing="0.05" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/headerNewScan"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        app:cardBackgroundColor="#33757575"
        app:cardElevation="0dp"
        app:cardCornerRadius="28dp"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toBottomOf="@id/header">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="NEW SCAN"
            android:textColor="@color/onSurfaceVariant"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardDocTypes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp"
        app:cardBackgroundColor="@color/surface"
        app:cardElevation="0dp"
        app:strokeWidth="1dp"
        app:strokeColor="@color/outline"
        app:cardCornerRadius="16dp"
        app:layout_constraintBottom_toTopOf="@id/bottomButtons"
        app:layout_constraintTop_toBottomOf="@id/headerNewScan">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Document Type"
                android:textColor="@color/onSurfaceVariant"
                android:textSize="14sp"
                android:layout_marginBottom="16dp" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnForm1"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginBottom="8dp"
                        android:text="Land Approval Form"
                        android:textAllCaps="false"
                        android:textColor="@color/onSurface"
                        android:gravity="start|center_vertical"
                        app:icon="@drawable/ic_description"
                        app:iconTint="@color/primary"
                        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.Button.Rounded" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnForm2"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginBottom="8dp"
                        android:text="Crop Registration Form"
                        android:textAllCaps="false"
                        android:textColor="@color/onSurface"
                        android:gravity="start|center_vertical"
                        app:icon="@drawable/ic_description"
                        app:iconTint="@color/primary"
                        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.Button.Rounded" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnForm3"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginBottom="8dp"
                        android:text="Field Inspection Report"
                        android:textAllCaps="false"
                        android:textColor="@color/onSurface"
                        android:gravity="start|center_vertical"
                        app:icon="@drawable/ic_description"
                        app:iconTint="@color/primary"
                        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.Button.Rounded" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnForm4"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginBottom="8dp"
                        android:text="Final Field Inspection"
                        android:textAllCaps="false"
                        android:textColor="@color/onSurface"
                        android:gravity="start|center_vertical"
                        app:icon="@drawable/ic_description"
                        app:iconTint="@color/primary"
                        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.Button.Rounded" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnForm5"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginBottom="8dp"
                        android:text="Seed Test Request Form"
                        android:textAllCaps="false"
                        android:textColor="@color/onSurface"
                        android:gravity="start|center_vertical"
                        app:icon="@drawable/ic_description"
                        app:iconTint="@color/primary"
                        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.Button.Rounded" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnForm6"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginBottom="8dp"
                        android:text="Seed Test Report"
                        android:textAllCaps="false"
                        android:textColor="@color/onSurface"
                        android:gravity="start|center_vertical"
                        app:icon="@drawable/ic_description"
                        app:iconTint="@color/primary"
                        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.Button.Rounded" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnForm7"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginBottom="8dp"
                        android:text="Labeling Document"
                        android:textAllCaps="false"
                        android:textColor="@color/onSurface"
                        android:gravity="start|center_vertical"
                        app:icon="@drawable/ic_description"
                        app:iconTint="@color/primary"
                        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.Button.Rounded" />

                </LinearLayout>
            </ScrollView>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/bottomButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHistory"
            style="@style/AppButton.Outlined"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:text="View History"
            android:textColor="@color/onSurface"
            app:icon="@drawable/ic_history"
            app:iconTint="@color/primary"
            app:iconGravity="textStart" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSettings"
            style="@style/AppButton.Outlined"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Scanner Settings"
            android:textColor="@color/onSurface"
            android:enabled="false"
            app:icon="@drawable/ic_settings"
            app:iconTint="@color/outline"
            app:iconGravity="textStart" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>