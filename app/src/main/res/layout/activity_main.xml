<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="AgroTrace"
        android:textColor="#212121"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toTopOf="@id/btnHistory"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <Button
                android:id="@+id/btnForm1"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:text="Scan Document Type 1\n(Land Approval Form)"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btnForm2"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:text="Scan Document Type 2\n(Crop Registration Form)"
                android:textSize="16sp" />

            <Button
                android:id="@+id/btnForm3"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:enabled="false"
                android:text="Scan Document Type 3\n(Coming Soon)"
                android:textSize="16sp"
                style="@style/Widget.Material3.Button.TonalButton" />

            <Button
                android:id="@+id/btnForm4"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:enabled="false"
                android:text="Scan Document Type 4\n(Coming Soon)"
                android:textSize="16sp"
                style="@style/Widget.Material3.Button.TonalButton" />

            <Button
                android:id="@+id/btnForm5"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:enabled="false"
                android:text="Scan Document Type 5\n(Coming Soon)"
                android:textSize="16sp"
                style="@style/Widget.Material3.Button.TonalButton" />

            <Button
                android:id="@+id/btnForm6"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:enabled="false"
                android:text="Scan Document Type 6\n(Coming Soon)"
                android:textSize="16sp"
                style="@style/Widget.Material3.Button.TonalButton" />

            <Button
                android:id="@+id/btnForm7"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:enabled="false"
                android:text="Scan Document Type 7\n(Coming Soon)"
                android:textSize="16sp"
                style="@style/Widget.Material3.Button.TonalButton" />

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnHistory"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="📋  View History"
        android:textSize="18sp"
        style="@style/Widget.Material3.Button.OutlinedButton"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>